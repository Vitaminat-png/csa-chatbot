# ============================================================
# CSA AI Chatbot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env with real keys to version control.
# ============================================================

# --- OpenAI ---
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE

# --- Pinecone ---
# Get your key at https://app.pinecone.io/
# Free tier: 1 index, up to 100K vectors (sufficient for CSA docs)
PINECONE_API_KEY=YOUR_PINECONE_API_KEY_HERE

# Index name you created in Pinecone console:
#   dimension: 1536  (matches text-embedding-3-small)
#   metric:    cosine
PINECONE_INDEX_NAME=csa-chatbot

# --- App Settings (optional overrides) ---
# TOP_K=5
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# API_HOST=0.0.0.0
# API_PORT=8000
